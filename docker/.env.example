# Required: Generate a random secret for NextAuth
# openssl rand -base64 32
NEXTAUTH_SECRET=

# Required: The public URL of your IronPulse instance
NEXTAUTH_URL=http://localhost:3000

# Optional: PowerSync RSA keys (auto-generated if not set)
POWERSYNC_PRIVATE_KEY=
POWERSYNC_PUBLIC_KEY=

# Optional: OAuth providers
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_ID=
APPLE_SECRET=

# Optional: Strava Integration
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_WEBHOOK_VERIFY_TOKEN=
DEVICE_TOKEN_ENCRYPTION_KEY=

# Garmin Connect
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=

# Optional: Stripe
STRIPE_PRICE_COACH_MONTHLY=
STRIPE_PRICE_COACH_YEARLY=
