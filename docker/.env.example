# ─────────────────────────────────────────────────────────────
# IronPulse self-hosting configuration. Copy to `.env` and edit.
#   cp .env.example .env
# Only NEXTAUTH_SECRET is strictly required; everything else has a
# safe default or enables an optional integration.
# ─────────────────────────────────────────────────────────────

# REQUIRED — session signing secret. Generate one with:
#   openssl rand -base64 32
NEXTAUTH_SECRET=

# REQUIRED for any non-localhost deployment — the public URL users hit.
# Must match the address in the browser (and your reverse proxy), or
# logins will fail. Example: https://fitness.example.com
NEXTAUTH_URL=http://localhost:3000

# ── Database ──────────────────────────────────────────────────
# The postgres container and the app default to these. They are only
# reachable on the internal compose network, not exposed to the host.
# Used by the nightly `backup` service. If you change them you must also
# update the postgres service env AND the DATABASE_URL in docker-compose.yml.
POSTGRES_USER=ironpulse
POSTGRES_PASSWORD=ironpulse
POSTGRES_DB=ironpulse

# ── PowerSync (offline mobile/web sync) ───────────────────────
# RSA keypair for signing sync tokens. Auto-generated if left blank.
POWERSYNC_PRIVATE_KEY=
POWERSYNC_PUBLIC_KEY=

# ── Optional: AI workout generation ───────────────────────────
# Self-hosters supply their own OpenAI key; usage is billed to that key.
# Leave blank to disable the AI-workout feature.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# ── Optional: OAuth sign-in providers ─────────────────────────
# Register an OAuth app with each provider and set the redirect URL to
# <NEXTAUTH_URL>/api/auth/callback/<provider>.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
APPLE_ID=
APPLE_SECRET=

# ── Optional: transactional email (password reset, etc.) ──────
RESEND_API_KEY=
EMAIL_FROM=IronPulse <noreply@ironpulse.app>

# ── Optional: Stripe (coach subscriptions) ────────────────────
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_COACH_MONTHLY=
STRIPE_PRICE_COACH_YEARLY=

# ── Optional: meal photo scanning (Clarifai vision API) ───────
MEAL_SCAN_API_KEY=

# ── Optional: fitness device integrations ─────────────────────
# DEVICE_TOKEN_ENCRYPTION_KEY encrypts stored device OAuth tokens at rest.
# Generate with: openssl rand -hex 32
DEVICE_TOKEN_ENCRYPTION_KEY=
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_WEBHOOK_VERIFY_TOKEN=
GARMIN_CLIENT_ID=
GARMIN_CLIENT_SECRET=
