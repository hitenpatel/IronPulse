{
  "cli": { "version": ">= 12.0.0" },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "ios": { "simulator": true },
      "distribution": "internal",
      "android": { "buildType": "apk" }
    },
    "e2e": {
      "extends": "preview",
      "android": { "buildType": "apk" },
      "env": {
        "//": "EXPO_PUBLIC_E2E only sets the coexist applicationId (com.ironpulse.app.e2e) in app.config — Config.E2E is unused, so the app is byte-for-byte the production UI. Do NOT set bare E2E here: that triggers the App.e2e mock + PowerSync stub in metro.config, which would build a fake app.",
        "EXPO_PUBLIC_E2E": "1",
        "EXPO_PUBLIC_API_URL": "http://100.113.79.51:3000"
      }
    },
    "production": {
      "autoIncrement": true,
      "android": { "buildType": "app-bundle" },
      "ios": { "resourceClass": "m-medium" }
    }
  },
  "submit": {
    "production": {
      "android": {
        "serviceAccountKeyPath": "./google-play-service-account.json",
        "track": "internal"
      },
      "ios": {
        "appleId": "SET_ME_APPLE_ID@example.com",
        "ascAppId": "SET_ME_APP_STORE_CONNECT_APP_ID",
        "appleTeamId": "SET_ME_APPLE_TEAM_ID"
      }
    }
  }
}
