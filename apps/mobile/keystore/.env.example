# Android release signing config. Copy to .env and fill in real values.
#
# The .env file in this directory is gitignored. Never commit it.
#
# For production Play Store release: use a keystore stored in a password
# manager (not generated locally). Follow the runbook at:
# https://docs.hiten-patel.co.uk/books/iron-pulse/page/android-app-signing

# Absolute path, or path relative to apps/mobile/android/app/ (where gradle
# resolves `file(...)`) to the keystore.
IRONPULSE_KEYSTORE_FILE=../../keystore/ironpulse-upload.jks

# Passwords. Keystore and key passwords can be the same.
IRONPULSE_KEYSTORE_PASSWORD=change-me-before-production
IRONPULSE_KEY_PASSWORD=change-me-before-production

# Key alias inside the keystore (created with `keytool -genkeypair -alias`)
IRONPULSE_KEY_ALIAS=ironpulse
