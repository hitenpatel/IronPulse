{
  "expo": {
    "name": "IronPulse",
    "slug": "ironpulse",
    "version": "1.0.0",
    "scheme": "ironpulse",
    "userInterfaceStyle": "dark",
    "ios": {
      "bundleIdentifier": "com.ironpulse.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.ironpulse.app",
      "adaptiveIcon": {
        "backgroundColor": "#0a0e1a"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ]
  }
}
