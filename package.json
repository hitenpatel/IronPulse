{
  "name": "ironpulse",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:push": "pnpm --filter @ironpulse/db db:push",
    "db:migrate": "pnpm --filter @ironpulse/db db:migrate",
    "db:seed": "pnpm --filter @ironpulse/db db:seed",
    "db:studio": "pnpm --filter @ironpulse/db db:studio",
    "changelog": "changelogen",
    "cleanup:tokens": "tsx packages/db/scripts/cleanup-expired-tokens.ts",
    "prepare": "husky"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "react": "19.1.0",
      "react-dom": "19.1.0",
      "babel-preset-expo": "~54.0.10"
    }
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.4.0",
    "changelogen": "^0.6.2",
    "eslint": "^9.39.4",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.59.1",
    "react-native-worklets": "0.7.4",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.58.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
