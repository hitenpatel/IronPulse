{
  "name": "ironpulse",
  "private": true,
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "db:push": "pnpm --filter @ironpulse/db db:push",
    "db:migrate": "pnpm --filter @ironpulse/db db:migrate",
    "db:seed": "pnpm --filter @ironpulse/db db:seed",
    "db:studio": "pnpm --filter @ironpulse/db db:studio",
    "changelog": "changelogen",
    "cleanup:tokens": "tsx packages/db/scripts/cleanup-expired-tokens.ts"
  },
  "packageManager": "pnpm@9.15.4",
  "pnpm": {
    "overrides": {
      "react": "19.1.0"
    }
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "changelogen": "^0.6.2",
    "turbo": "^2.8.16",
    "typescript": "^5.9.3"
  }
}
